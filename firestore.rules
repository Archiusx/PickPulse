rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: inventory
    // Fields: name, category, stock, minStock, expiryDate, location, pickingFrequency, barcode
    //
    // Collection: compliance
    // Fields: type, value, timestamp, status
    //
    // Collection: tickets
    // Fields: userId, userEmail, type, description, status, timestamp, itemId
    //
    // Collection: approvals
    // Fields: userId, userEmail, type, details, status, timestamp, orderId
    //
    // Collection: vendor_messages
    // Fields: senderId, senderName, senderRole, text, timestamp, vendorId
    //
    // Collection: orders
    // Fields: orderId, itemsPicked, totalItems, pickerName, pickerEmail, pickerId, startTime, endTime, timeTakenMinutes, status, issues
    //
    // Collection: picker_status
    // Fields: name, status, currentZone, lastActive
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
         (request.auth.token.email == "adityadeshakar@gmail.com" && request.auth.token.email_verified == true));
    }

    function isManager() {
      return isAuthenticated() &&
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Manager'));
    }

    function isValidUser(data) {
      return data.email is string && 
             data.role in ['Admin', 'Manager', 'Picker'] &&
             data.displayName is string;
    }

    function isValidInventory(data) {
      return data.name is string && data.name.size() < 100 &&
             data.stock is number && data.stock >= 0 &&
             data.minStock is number && data.minStock >= 0;
    }

    function isValidCompliance(data) {
      return data.type in ['temperature', 'cleaning', 'regulatory'] &&
             data.status in ['normal', 'warning', 'critical'];
    }

    function isValidTicket(data) {
      return data.type in ['qr_not_visible', 'product_not_found', 'damaged', 'other', 'qr_unreadable', 'stock_discrepancy', 'product_missing'] &&
             data.status in ['open', 'resolved', 'closed'];
    }

    function isValidApproval(data) {
      return data.type in ['emergency_complete', 'new_stock', 'price_change'] &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidOrder(data) {
      return data.orderId is string &&
             data.status in ['picking', 'completed', 'emergency_completed', 'pending_packing'];
    }

    function isValidPickerStatus(data) {
      return data.status in ['picking', 'idle', 'break'] &&
             data.currentZone is string;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
      
      match /history/{historyId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }

    match /compliance/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /tickets/{ticketId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTicket(request.resource.data);
      allow update: if isManager() && isValidTicket(request.resource.data);
    }

    match /approvals/{approvalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidApproval(request.resource.data);
      allow update: if isManager() && isValidApproval(request.resource.data);
    }

    match /vendor_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.text.size() < 1000;
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && isValidOrder(request.resource.data);
    }

    match /picker_status/{pickerId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == pickerId || isAdmin());
    }
  }
}
